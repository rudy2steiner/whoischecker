# Supabase Postgres — Prisma reads/writes `domain_whois_cache`.
# Use the pooler URL with `?pgbouncer=true` (see Prisma + Supabase docs).
#
# For `npx prisma db push` / migrate, temporarily use the *direct* Postgres URI (port 5432,
# host db.*.supabase.co) as DATABASE_URL, or run SQL migrations in the Supabase SQL editor.
#
# IMPORTANT: Encode special characters in the password (see Prisma connection URL docs).
#
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:ENCODED_PASSWORD@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Cache TTL (seconds). If DOMAIN_CACHE_TTL_ERROR_SECONDS=0, error responses are NOT cached (only query_count may update).
# DOMAIN_CACHE_TTL_UNAVAILABLE_SECONDS=3600
# DOMAIN_CACHE_TTL_AVAILABLE_SECONDS=300
# DOMAIN_CACHE_TTL_ERROR_SECONDS=0
